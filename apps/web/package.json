{
  "name": "ironrag-frontend",
  "private": true,
  "version": "0.4.4",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:watch": "vitest",
    "bundle:check": "node scripts/check-bundle-budget.mjs",
    "size-limit": "size-limit",
    "deadcode:ts-prune": "ts-prune"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/context-zone-peer-dep": "^2.7.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.216.0",
    "@opentelemetry/instrumentation": "^0.216.0",
    "@opentelemetry/instrumentation-document-load": "^0.61.0",
    "@opentelemetry/instrumentation-fetch": "^0.216.0",
    "@opentelemetry/instrumentation-user-interaction": "^0.60.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-trace-web": "^2.7.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sigma/edge-curve": "^3.1.0",
    "@tanstack/react-query": "^5.100.9",
    "@tiptap/extension-table": "^3.22.5",
    "@tiptap/extension-table-cell": "^3.22.5",
    "@tiptap/extension-table-header": "^3.22.5",
    "@tiptap/extension-table-row": "^3.22.5",
    "@tiptap/markdown": "^3.22.5",
    "@tiptap/react": "^3.22.5",
    "@tiptap/starter-kit": "^3.22.5",
    "@types/swagger-ui-react": "^5.18.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "graphology": "^0.26.0",
    "i18next": "^26.0.8",
    "lucide-react": "1.14.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.75.0",
    "react-i18next": "^17.0.6",
    "react-markdown": "^10.1.0",
    "react-router-dom": "7.15.0",
    "sigma": "^3.0.3",
    "sonner": "2.0.7",
    "swagger-ui-react": "^5.32.5",
    "tailwind-merge": "3.5.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "size-limit": [
    {
      "name": "main entry chunk",
      "path": "dist/assets/index-*.js",
      "limit": "150 KB",
      "gzip": true
    },
    {
      "name": "Sigma vendor chunk",
      "path": "dist/assets/vendor-sigma-*.js",
      "limit": "200 KB",
      "gzip": true
    },
    {
      "name": "Tiptap vendor chunk",
      "path": "dist/assets/vendor-tiptap-*.js",
      "limit": "180 KB",
      "gzip": true
    },
    {
      "name": "Swagger UI vendor chunk",
      "path": "dist/assets/vendor-swagger-*.js",
      "limit": "400 KB",
      "gzip": true
    }
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@hey-api/openapi-ts": "0.97.1",
    "@playwright/test": "^1.59.1",
    "@size-limit/file": "^12.1.0",
    "@storybook/addon-a11y": "^10.3.6",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/addon-themes": "^10.3.6",
    "@storybook/react": "^10.3.6",
    "@storybook/react-vite": "^10.3.6",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/eslint-plugin-query": "5.100.9",
    "@tanstack/react-query-devtools": "^5.100.9",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "js-yaml": "^4.1.1",
    "jsdom": "^29.1.1",
    "knip": "^6.11.0",
    "msw": "^2.14.3",
    "msw-storybook-addon": "^2.0.7",
    "size-limit": "^12.1.0",
    "storybook": "^10.3.6",
    "tailwindcss": "^4.2.4",
    "ts-prune": "^0.10.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
