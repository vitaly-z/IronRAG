# Docker Compose reads this file from the repository root automatically.
# Keep only canonical IRONRAG_* and standard OTEL_* variables here; do not mix lower-case aliases.
# docker-compose.yml uses prebuilt Docker Hub images by default.
# docker-compose-local.yml keeps the manual source-build path.

# Published HTTP port for frontend -> UI/API/MCP.
IRONRAG_PORT=19000

# Basic stack defaults for the filesystem compose profile.
IRONRAG_ENVIRONMENT=ironrag-sources
IRONRAG_POSTGRES_DB=ironrag
IRONRAG_POSTGRES_USER=postgres
IRONRAG_POSTGRES_PASSWORD=postgres
IRONRAG_ARANGODB_PASSWORD=ironrag-dev
IRONRAG_DATABASE_MAX_CONNECTIONS=20
IRONRAG_LOG_FILTER=info
IRONRAG_FRONTEND_ORIGIN=http://127.0.0.1:19000,http://localhost:19000
# Optional first-login bootstrap.
IRONRAG_UI_BOOTSTRAP_ADMIN_LOGIN=
IRONRAG_UI_BOOTSTRAP_ADMIN_PASSWORD=
IRONRAG_UI_BOOTSTRAP_ADMIN_API_TOKEN=

# Optional first-run model defaults.
IRONRAG_UI_BOOTSTRAP_EXTRACT_GRAPH_PROVIDER_KIND=openai
IRONRAG_UI_BOOTSTRAP_EXTRACT_GRAPH_MODEL_NAME=gpt-5.4-nano
IRONRAG_UI_BOOTSTRAP_EMBED_CHUNK_PROVIDER_KIND=openai
IRONRAG_UI_BOOTSTRAP_EMBED_CHUNK_MODEL_NAME=text-embedding-3-large
IRONRAG_UI_BOOTSTRAP_QUERY_ANSWER_PROVIDER_KIND=openai
IRONRAG_UI_BOOTSTRAP_QUERY_ANSWER_MODEL_NAME=gpt-5.4-mini
IRONRAG_UI_BOOTSTRAP_VISION_PROVIDER_KIND=openai
IRONRAG_UI_BOOTSTRAP_VISION_MODEL_NAME=gpt-5.4-mini

# Optional provider secrets.
IRONRAG_OPENAI_API_KEY=
IRONRAG_DEEPSEEK_API_KEY=
IRONRAG_QWEN_API_KEY=
IRONRAG_GPTUNNEL_API_KEY=
IRONRAG_OPENROUTER_API_KEY=
IRONRAG_ROUTERAI_API_KEY=

# Ingestion tuning.
IRONRAG_INGESTION_MAX_PARALLEL_JOBS_GLOBAL=64
IRONRAG_INGESTION_MAX_PARALLEL_JOBS_PER_WORKSPACE=16
IRONRAG_INGESTION_MAX_PARALLEL_JOBS_PER_LIBRARY=4
IRONRAG_DOCLING_PAGE_BATCH_SIZE=10
IRONRAG_DOCLING_PAGE_STREAM_WINDOW_PAGES=40
IRONRAG_DOCLING_MAX_CONCURRENCY=1
IRONRAG_INGESTION_HEAVY_PIPELINE_PARALLELISM=1
IRONRAG_INGESTION_EMBEDDING_PARALLELISM=8
IRONRAG_INGESTION_GRAPH_EXTRACT_PARALLELISM_PER_DOC=16

# Retrieval tuning.
# IRONRAG_QUERY_RERANK_ENABLED=true
# IRONRAG_QUERY_RERANK_CANDIDATE_LIMIT=20
# IRONRAG_QUERY_BALANCED_CONTEXT_ENABLED=true
# IRONRAG_QUERY_ANSWER_SOURCE_LINKS_ENABLED=false

# Web crawl defaults.
# IRONRAG_WEB_INGEST_HTTP_TIMEOUT_SECONDS=30
# IRONRAG_WEB_INGEST_MAX_REDIRECTS=5

# Optional runtime policy controls for operator smoke and intervention drills.
# IRONRAG_RUNTIME_POLICY_REJECT_TASK_KINDS=
# IRONRAG_RUNTIME_POLICY_REJECT_TARGET_KINDS=

# OpenTelemetry OTLP export for traces, metrics and logs (default protocol is gRPC).
# IRONRAG_OTEL_ENABLED=true
# OTEL_RESOURCE_ATTRIBUTES=service.namespace=ironrag
# OTEL_DEPLOYMENT_ENVIRONMENT=prod
# OTEL_TRACES_EXPORTER=otlp
# OTEL_METRICS_EXPORTER=otlp
# OTEL_LOGS_EXPORTER=otlp
# OTEL_EXPORTER_OTLP_PROTOCOL=grpc
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otel.example.com:4317
# OTEL_EXPORTER_OTLP_METRICS_TEMPORALITY_PREFERENCE=cumulative
# HTTP/protobuf fallback:
# OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otel.example.com:4318
# Browser traces are baked into the frontend image at build time.
# VITE_OTEL_EXPORTER_OTLP_ENDPOINT=https://otel.example.com:4318/v1/traces
# VITE_OTEL_SERVICE_NAME=ironrag-web
# VITE_OTEL_DEPLOYMENT_ENVIRONMENT=prod

# Optional image overrides for prebuilt or internal deployments.
# IRONRAG_BACKEND_IMAGE=pipingspace/ironrag-backend:latest
# IRONRAG_FRONTEND_IMAGE=pipingspace/ironrag-frontend:latest
# IRONRAG_POSTGRES_IMAGE=postgres:18-alpine
# IRONRAG_REDIS_IMAGE=redis:8.6
# IRONRAG_ARANGODB_IMAGE=arangodb:3.12.4
# IRONRAG_S4CORE_IMAGE=s4core/s4core:latest

# Compose profiles:
# - docker-compose.yml: bundled Postgres/Redis/ArangoDB + filesystem storage
# - docker-compose-s4.yml: same stack + bundled s4core with IronRAG configured for S3
#
# Advanced runtime overrides such as external dependency URLs or manual deployment modes
# are intentionally not listed here to keep the common compose path small.
# See apps/api/.env.example when you need the full runtime surface.
